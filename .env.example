# Copy this file to .env and fill in your values.
# Secrets (DB credentials, JWT, Fernet) are stored in AWS Secrets Manager
# and loaded automatically at startup — do NOT put them here in production.

# ── AWS Secrets Manager ────────────────────────────────────────────────────────
# Region where your secret lives
AWS_REGION=eu-west-1

# Full name of the secret in Secrets Manager (e.g. "proxmox-manager/config")
AWS_SECRET_NAME=proxmox-manager/config

# IAM credentials with secretsmanager:GetSecretValue permission.
# Leave blank on ECS/EC2 — the task/instance role is used automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Local dev fallback (used only when AWS_REGION / AWS_SECRET_NAME are blank) ─
# These values are ignored when Secrets Manager is configured.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=proxmox_manager
DB_USER=pmxuser
DB_PASSWORD=pmxpass

JWT_SECRET=change-me-in-production-please

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Non-sensitive ──────────────────────────────────────────────────────────────
CORS_ORIGINS=*
