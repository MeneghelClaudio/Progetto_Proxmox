# Copy this file to .env and adjust values for production use.

# Database
DB_NAME=proxmox_manager
DB_USER=pmxuser
DB_PASSWORD=pmxpass
DB_ROOT_PASSWORD=rootpass

# JWT signing secret (change this to a long random string)
JWT_SECRET=change-me-in-production-please

# Optional: provide your own Fernet key (base64, 32 bytes). If blank, one is
# generated and stored in the backend volume at /data/fernet.key.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
